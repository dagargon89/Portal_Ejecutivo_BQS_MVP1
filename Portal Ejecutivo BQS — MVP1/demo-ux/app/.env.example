# Interruptor de origen de datos (Demo-First v2 §5).
# true  -> usa el adaptador mock (lib/api.mock.ts) que lee db.json espejo del DDL.
# false -> usa el adaptador real (lib/api.real.ts) contra la API CI4 (Fase 2).
VITE_USE_MOCK=true

# Base URL de la API real. Solo se usa cuando VITE_USE_MOCK=false (Fase 2).
VITE_API_URL=https://bqs.dataholics.com.mx/api
